{
  "name": "mongo-k8s-sidecar",
  "version": "0.17.5",
  "description": "Kubernetes sidecar for MongoDB",
  "main": "src/index.ts",
  "type": "module",
  "author": "Solidatus",
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "watch": "tsc -w"
  },
  "engines": {
    "node": "^24.0.0",
    "node-comment": "Keep in sync with .nvmrc & the global npm update (major version) in Dockerfile"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "mongodb": "^7.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.4",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  }
}
